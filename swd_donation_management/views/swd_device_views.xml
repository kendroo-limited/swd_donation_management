<odoo>
    <record id="view_swd_device_tree" model="ir.ui.view">
        <field name="name">swd.device.tree</field>
        <field name="model">swd.device</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="device_number"/>
                <field name="device_type"/>
                <field name="patient_id"/>
                <field name="issue_date"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'available'"
                    decoration-warning="state == 'issued'"
                    decoration-info="state == 'returned'"
                    decoration-danger="state == 'lost'"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_device_form" model="ir.ui.view">
        <field name="name">swd.device.form</field>
        <field name="model">swd.device</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_issued" string="Issue" type="object" class="oe_highlight" invisible="state != 'available'"/>
                    <button name="action_mark_returned" string="Return" type="object" class="oe_highlight" invisible="state != 'issued'"/>
                    <button name="action_mark_lost" string="Mark Lost" type="object" class="oe_highlight" invisible="state not in ('available', 'issued')"/>
                    <button name="action_mark_available" string="Set Available" type="object" class="oe_highlight" invisible="state == 'available'"/>
                    <field name="state" widget="statusbar" statusbar_visible="available,issued,returned,lost"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Standard Wheelchair"/>
                        </h1>
                    </div>
                    <group>
                        <group col="2">
                            <field name="patient_id"/>
                        <field name="device_number"/>
                        <field name="device_type"/>
                    </group>
                    <group col="2">
                        
                        <field name="issue_date"/>
                        <field name="return_date"/>
                    </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Add issue/return notes, condition, or remarks..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_device" model="ir.actions.act_window">
        <field name="name">Assistive Devices</field>
        <field name="res_model">swd.device</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

<odoo>
    <record id="view_swd_patient_category_tree" model="ir.ui.view">
        <field name="name">swd.patient.category.tree</field>
        <field name="model">swd.patient.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_patient_category_form" model="ir.ui.view">
        <field name="name">swd.patient.category.form</field>
        <field name="model">swd.patient.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="description"/>
                    </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_patient_category" model="ir.actions.act_window">
        <field name="name">Patient Categories</field>
        <field name="res_model">swd.patient.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_swd_patient_tree" model="ir.ui.view">
        <field name="name">swd.patient.tree</field>
        <field name="model">swd.patient</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="category_id"/>
                <field name="patient_type"/>
                <field name="socioeconomic_status"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_patient_form" model="ir.ui.view">
    <field name="name">swd.patient.form</field>
    <field name="model">swd.patient</field>
    <field name="arch" type="xml">
        <form>
            
            <sheet>
                <header>
                <field name="active" widget="boolean_toggle"/>
            </header>
                <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name" placeholder="Select Patient"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="category_id"/>
                        <field name="patient_type"/>
                    </group>
                    <group>
                        <field name="socioeconomic_status"/>
                        <field name="eligibility_notes"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
</record>

    <record id="action_swd_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">swd.patient</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

<odoo>
    <record id="view_swd_fund_tree" model="ir.ui.view">
        <field name="name">swd.fund.tree</field>
        <field name="model">swd.fund</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="fund_type"/>
                <field name="donor_id"/>
                <field name="total_contributed"/>
                <field name="total_subsidized"/>
                <field name="balance"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_fund_form" model="ir.ui.view">
        <field name="name">swd.fund.form</field>
        <field name="model">swd.fund</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name" placeholder="e.g. General Charity Fund"/>
                    </h1>
                </div>
                    <group>
                        <group>
                        
                        <field name="code"/>
                        <field name="fund_type"/>
                        <field name="donor_id"/>
                        <field name="currency_id"/>
                        
                    </group>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="total_contributed" readonly="1"/>
                        <field name="total_subsidized" readonly="1"/>
                        <field name="balance" readonly="1"/>
                    </group>
                    </group>
                    <notebook>
                        <page string="Contributions">
                            <field name="contribution_ids">
                                <tree editable="bottom">
                                    <field name="donor_id"/>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="reference"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Projects">
                            <field name="project_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="department_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Subsidies">
                            <field name="subsidy_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="patient_id"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge"
                                        decoration-muted="state == 'draft'"
                                        decoration-info="state == 'approved'"
                                        decoration-success="state == 'paid'"
                                        decoration-danger="state == 'cancelled'"/>
                                    <field name="date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_fund" model="ir.actions.act_window">
        <field name="name">Funds</field>
        <field name="res_model">swd.fund</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_swd_contribution_tree" model="ir.ui.view">
        <field name="name">swd.contribution.tree</field>
        <field name="model">swd.contribution</field>
        <field name="arch" type="xml">
            <tree>
                <field name="fund_id"/>
                <field name="donor_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="reference"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_contribution_form" model="ir.ui.view">
        <field name="name">swd.contribution.form</field>
        <field name="model">swd.contribution</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="fund_id"/>
                        <h1>
                            <field name="fund_id" placeholder="Select a Fund"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="donor_id"/>
                        <field name="date"/>
                        
                        </group>
                        <group>
                            <field name="amount"/>
                        <field name="reference"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_contribution" model="ir.actions.act_window">
        <field name="name">Contributions</field>
        <field name="res_model">swd.contribution</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_swd_project_tree" model="ir.ui.view">
        <field name="name">swd.project.tree</field>
        <field name="model">swd.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="fund_id"/>
                <field name="department_id"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_project_form" model="ir.ui.view">
        <field name="name">swd.project.form</field>
        <field name="model">swd.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <field name="active" widget="boolean_toggle"/>
                    </header>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. SCI Rehabilitation Project"/>
                        </h1>
                    </div>
                    <group>
                        <group col="2">
                        <field name="code"/>
                        <field name="fund_id"/>
                    </group>
                    <group col="2">
                        <field name="department_id"/>
                        <field name="description" placeholder="Write project details, scope, and objectives..."/>
                    </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_project" model="ir.actions.act_window">
        <field name="name">Projects / Grants</field>
        <field name="res_model">swd.project</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_swd_donor_tree" model="ir.ui.view">
        <field name="name">swd.donor.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="donor_code"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="company_type"/>
                <field name="is_donor"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_donor_form" model="ir.ui.view">
        <field name="name">swd.donor.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="donor_code"/>
                        <field name="is_donor"/>
                    </group>
                    <group>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="company_type"/>
                    </group>
                    <group>
                        <field name="street"/>
                        <field name="city"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_donor" model="ir.actions.act_window">
        <field name="name">Donors</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[("is_donor", "=", True)]</field>
        <field name="context">{"default_is_donor": True}</field>
    </record>
</odoo>

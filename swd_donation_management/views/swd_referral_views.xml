<odoo>
    <record id="view_swd_referral_tree" model="ir.ui.view">
        <field name="name">swd.referral.tree</field>
        <field name="model">swd.referral</field>
        <field name="arch" type="xml">
            <tree>
                <field name="patient_id"/>
                <field name="msw_user_id"/>
                <field name="referral_date"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_swd_referral_form" model="ir.ui.view">
        <field name="name">swd.referral.form</field>
        <field name="model">swd.referral</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <field name="active" widget="boolean_toggle"/>
                    </header>
                    <group>
                        <group col="2">
                        <field name="patient_id"/>
                        <field name="msw_user_id"/>
                    </group>
                    <group col="2">
                        <field name="referral_date"/>
                        <field name="report_summary" placeholder="Write a concise referral summary..."/>
                    </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_swd_referral" model="ir.actions.act_window">
        <field name="name">Referrals</field>
        <field name="res_model">swd.referral</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
